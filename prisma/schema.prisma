generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  reminders    Reminder[]

  @@index([email])
}

model Reminder {
  id           String         @id @default(cuid())
  userId       String?
  user         User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  body         String
  reminderDate String
  status       String         @default("ACTIVE")
  notifiedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  notifications Notification[]

  @@index([reminderDate, status])
  @@index([userId, reminderDate, status])
}

model Notification {
  id           String    @id @default(cuid())
  reminderId   String
  reminder     Reminder  @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  title        String
  body         String
  reminderDate String
  deliveredAt  DateTime  @default(now())
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@unique([reminderId, reminderDate])
  @@index([readAt, reminderDate])
}
